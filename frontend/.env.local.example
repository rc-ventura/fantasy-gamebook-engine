# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit secrets.

# Base URL for the FastAPI backend API.
# In development the Vite proxy rewrites /api/* → http://localhost:8000/*
# so this is typically left as /api (the default in the typed client).
VITE_API_BASE=/api

# Dev auth stub token (slice 003's hardcoded bearer).
# Used by the typed API client until slice 004 delivers real OIDC.
# When real OIDC lands, remove this variable; the auth seam handles the rest.
VITE_DEV_TOKEN=dev-stub-token
